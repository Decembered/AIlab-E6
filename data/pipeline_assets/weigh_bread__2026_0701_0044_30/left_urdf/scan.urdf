<?xml version="1.0"?>
<robot name="bread">
  <material name="obj_color">
    <color rgba="0.8 0.6 0.4 1.0"/>
  </material>
  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="scan.obj" scale="1 1 1"/></geometry>
      <material name="obj_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="scan.obj" scale="1 1 1"/></geometry>
    </collision>
  </link>
</robot>
