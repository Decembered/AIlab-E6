<?xml version="1.0"?>
<robot name="bread">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.240000"/>
      <inertia
        ixx="0.00032800" ixy="0.0" ixz="0.0"
        iyy="0.00065000" iyz="0.0"
        izz="0.00057800"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="bread_extruded.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="bread_mat">
        <color rgba="0.82 0.71 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="bread_extruded.obj" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>
</robot>
