               iyy="0.004696" iyz="0.0"
               izz="0.004381"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../mesh/visual_mesh.obj" scale="1 1 1"/></geometry>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
