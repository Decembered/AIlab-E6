<?xml version="1.0"?>
<robot name="pipette_articulated">
  <!-- Base link: main pipette body -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.120000"/>
      <inertia ixx="0.00007625" ixy="0" ixz="0" iyy="0.00073789" iyz="0" izz="0.00066964"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="pipette_base.obj" scale="1 1 1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="pipette_base_collision.obj" scale="1 1 1"/></geometry>
    </collision>
  </link>
  <!-- Plunger link: sliding button -->
  <link name="plunger_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.030000"/>
      <inertia ixx="0.00001829" ixy="0" ixz="0" iyy="0.00003374" iyz="0" izz="0.00001590"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="pipette_plunger.obj" scale="1 1 1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="pipette_plunger_collision.obj" scale="1 1 1"/></geometry>
    </collision>
  </link>
  <!-- Prismatic joint: plunger slides along X axis -->
  <joint name="plunger_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="plunger_link"/>
    <origin xyz="0.091746 0.000000 0.000000" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.0300" effort="10" velocity="0.1"/>
    <dynamics damping="5.0" friction="2.0"/>
  </joint>
</robot>
