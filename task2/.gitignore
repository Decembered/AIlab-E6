# Local data and generated artifacts are intentionally not committed.
data/
outputs/
logs/
tmp_visualization/
tmp_visualization_runs/
third_party/

# Keep curated GitHub-safe videos under media/.
!media/
!media/**

# Python caches
__pycache__/
*.py[cod]

# Model checkpoints and large binaries
*.pt
*.pth
*.ckpt
*.onnx
*.task

# Videos and raw media outside curated media/
*.mp4
*.mkv
*.avi
*.mov
!media/**/*.mp4

# Local secrets
.env
.env.*
!.env.example
